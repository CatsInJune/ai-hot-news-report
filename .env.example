# 数据库（PostgreSQL）
# 本地 Docker: docker compose up -d db
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ai_hot_news"

# AI 分析（必填，至少配置 DeepSeek 或 OpenRouter 一个）
# DeepSeek 直连（推荐，更便宜）
DEEPSEEK_API_KEY=""
# DEEPSEEK_MODEL="deepseek-chat"

# OpenRouter（备用，DeepSeek 未配置时走 OpenRouter）
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemini-2.5-flash"

# 是否用 LLM 清洗正文（默认 true）
# CLEAN_RAW_WITH_LLM="true"

# 数据采集
# Twitter/X（可选，twitterapi.io，没有则跳过 Twitter 采集源）
TWITTER_API_KEY=""
# Firecrawl（可选，用于网页正文抓取）
FIRECRAWL_API_KEY=""

# 邮件推送 SMTP（可选，未配置时不发邮件）
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-16-char-app-password"
SMTP_FROM_NAME="AI 热点速报"

# 接收通知的邮箱
NOTIFICATION_EMAIL="your@gmail.com"

# 企业微信群机器人 webhook（可选，多个用逗号分隔）
# 拿法：企业微信群 → 右上角··· → 群机器人 → 添加 → 复制 webhook URL
WECHAT_WEBHOOK_URL=""
# 单条 digest 最多展示几条命中（多余只显示数量），默认 5
WECHAT_DIGEST_MAX_LINES="5"

# 通知防轰炸：5 分钟窗口聚合一封 digest；条数达 MAX 立即发
EMAIL_DIGEST_WINDOW_MS="300000"
EMAIL_DIGEST_MAX_ITEMS="20"

# 应用配置
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 采集频率（cron 表达式，默认每30分钟）
# 注意：仅本地/长进程部署生效；Vercel 上不跑 node-cron，
# 线上定时由 GitHub Actions workflow (.github/workflows/collect.yml) 接管
COLLECTION_CRON="*/30 * * * *"

# 主动采集（生产 Vercel 必填，否则顶栏 Fetch 按钮 503）
# - GITHUB_TOKEN：fine-grained PAT，权限：Actions = Read and write
#   Settings → Developer settings → Personal access tokens → Fine-grained tokens
# - GITHUB_REPO：owner/repo，例如 CatsInJune/ai-hot-news-report
GITHUB_TOKEN=""
GITHUB_REPO=""
