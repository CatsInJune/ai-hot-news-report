// AI热点速报工具 - 数据库 Schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// 关键词监控配置
model Keyword {
  id            String   @id @default(cuid())
  name          String
  domain        String   @default("通用")
  active        Boolean  @default(true)
  priority      String   @default("medium")
  notifyBrowser Boolean  @default(true)
  notifyEmail   Boolean  @default(false)
  notifyWechat  Boolean  @default(false)
  // AI 扩展出的关键词变体 JSON 数组，例如 ["程序员鱼皮","鱼皮","yupi","@yupi996"]
  // 用于 Pre-match 的字面命中检测，首次采集时通过 AI 生成并缓存
  aliases       String?
  // 关联的平台账号 JSON 数组，例如 [{"platform":"twitter","handle":"yupi996"},{"platform":"bilibili","uid":"12345"}]
  // 用于账号检测：直接拉取该账号的 timeline，绕过关键词搜索
  accounts      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  topics        Topic[]
}

// 采集到的热点内容
model Topic {
  id          String   @id @default(cuid())
  title       String
  // AI 生成的 ~50 字摘要，用于卡片紧凑展示
  summary     String?
  // 采集到的原始描述/正文，用于"展开原文"。可能为空（HN 等）。
  rawContent  String?
  // 译文缓存，JSON map：{ "zh-CN": "...", "en": "..." }
  // 按需翻译时 LLM 写入，相同目标语言不重复调用；rawContent 重抓时清空
  translations String?
  url         String   @unique
  source      String
  sourceIcon  String?
  author      String?
  // 作者扩展元数据（目前仅 Twitter 真填，其他源默认 null）
  authorVerified  Boolean?
  authorFollowers Int?
  publishedAt DateTime

  // AI 分析结果
  realScore        Int     @default(0)
  relevScore       Int     @default(0)
  hotScore         Int     @default(0)
  isSpam           Boolean @default(false)
  reason           String?
  // 关键词字面是否被提及（pre-match 结果，区别于 AI 的语义相关性判断）
  keywordMentioned Boolean @default(false)
  // 对监控人的重要程度：low / medium / high / urgent
  // 邮件通知只对 high/urgent 触发，避免轰炸
  importance       String  @default("medium")
  // 来源类型：true 表示来自账号 timeline 订阅，false 表示来自关键词搜索
  subscribed       Boolean @default(false)

  // 互动数据
  likes    Int @default(0)
  reposts  Int @default(0)
  comments Int @default(0)
  views    Int @default(0)

  // 关联关键词
  keywordId String?
  keyword   Keyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([source])
  @@index([publishedAt])
  @@index([hotScore])
  @@index([createdAt])
}

// 通知记录
model Notification {
  id       String   @id @default(cuid())
  type     String
  title    String
  content  String
  topicUrl String?
  read     Boolean  @default(false)
  sentAt   DateTime @default(now())

  @@index([sentAt])
}

// 系统设置（K-V 存储）
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
